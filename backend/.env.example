# ─── Datasource ──────────────────────────────────────────────────────────────
# Im Docker-Stack: Host = Service-Name "postgres"
# Lokal: Host = localhost, Port = 3838 (gemappt im docker-compose.yml)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/brawltracker?currentSchema=brawltracker
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=changeme

# ─── Brawl Stars API ─────────────────────────────────────────────────────────
# API-Key von https://developer.brawlstars.com
BRAWL_API_KEY=your-brawl-stars-api-key-here
