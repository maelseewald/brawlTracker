# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Zugangsdaten für die PostgreSQL-Datenbank
POSTGRES_DB=brawltracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ─── Backend ─────────────────────────────────────────────────────────────────
# Brawl Stars API-Key von https://developer.brawlstars.com
BRAWL_API_KEY=your-brawl-stars-api-key-here

# ─── Nginx / Domain ──────────────────────────────────────────────────────────
# Domain, auf der die App läuft (ohne Protokoll)
DOMAIN=deinedomain.de
