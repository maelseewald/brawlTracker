# ─── Backend API ─────────────────────────────────────────────────────────────
# Basis-URL des Backends, die der Browser erreichen kann.
# In Produktion: leer lassen → nginx leitet /api weiter (same-origin)
# Lokal ohne Docker: http://localhost:29678
VITE_API_BASE_URL=

# ─── Vite Dev-Server Proxy ───────────────────────────────────────────────────
# Nur für lokale Entwicklung; KEIN VITE_-Prefix → nicht im Browser-Bundle
DEV_BACKEND_URL=http://localhost:29678

